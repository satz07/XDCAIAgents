# ── XDC Mainnet ──────────────────────────────────────────────
XDC_RPC_URL=https://erpc.xdcrpc.com
CHAIN_ID=50
USDC_ADDRESS=0xfA2958CB79b0491CC627c1557F441eF849Ca8eb1
USDC_DECIMALS=6
# Explorer: https://xdcscan.com

# ── XDC Apothem Testnet (comment mainnet above, uncomment below) ─
# XDC_RPC_URL=https://rpc.apothem.network
# XDC_RPC_FALLBACK_URL=https://earpc.apothem.network
# CHAIN_ID=51
# USDC_ADDRESS=0xb5AB69F7bBada22B28e79C8FFAECe55eF1c771D4
# USDC_DECIMALS=6
# Explorer: https://testnet.xdcscan.com  (tx links auto-use this on Apothem)
# Faucet:   https://faucet.apothem.network

# Wallet that PAYS for API calls (agent)
AGENT_PRIVATE_KEY=your_agent_wallet_private_key

# Wallet that RECEIVES API payments (server) — shown as "Receiver" balance in UI
PAY_TO_ADDRESS=your_server_receiving_address

# ── Marketplace ───────────────────────────────────────────────
TRAVALA_WALLET=travala_provider_wallet_address
PLATFORM_COMMISSION_WALLET=xdc_platform_commission_wallet
PLATFORM_COMMISSION_RATE=0.005
TRAVALA_SEARCH_PRICE_USDC=1.0
TRAVALA_MOCK_FLIGHT_PRICE_USDC=1.0

# ── Services ─────────────────────────────────────────────────
FX_API_PORT=4021
FX_API_URL=http://localhost:4021
AGENT_PORT=3005
HOST=0.0.0.0
FX_PRICE_USDC=0.1

# Demo mode: skip real on-chain verification (local testing without funds)
DEMO_MODE=true

# RPC timeout for balance lookups (Apothem can be slow)
BALANCE_RPC_TIMEOUT_MS=30000

# ── AI (optional — falls back to rule-based parser) ───────────
ANTHROPIC_API_KEY=
